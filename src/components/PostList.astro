---
import PostCard from './PostCard.astro';

interface Post {
  id: string;
  slug: string;
  body: string;
  data: {
    title: string;
    description?: string;
    date: Date;
    tags?: string[];
    category?: string;
    cover?: string;
    pinned?: boolean;
    draft?: boolean;
  };
}

interface Props {
  posts: Post[];
  heading?: string;
  hideCover?: boolean;
  routePrefix?: string;
}

const { posts, heading, hideCover = false, routePrefix = '/post/' } = Astro.props;
---

{
  posts.length > 0 && (
    <section>
      {heading && (
        <h2 class="text-xl font-bold mb-6 flex items-center gap-2">
          <span class="w-1 h-6 bg-primary rounded-full inline-block"></span>
          {heading}
        </h2>
      )}
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {posts.map((post) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            slug={post.slug}
            tags={post.data.tags}
            category={post.data.category}
            cover={post.data.cover}
            body={post.body}
            draft={post.data.draft}
            hideCover={hideCover}
            routePrefix={routePrefix}
          />
        ))}
      </div>
    </section>
  )
}
